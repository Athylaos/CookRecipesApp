@page "/"
@using Pinula.Shared.Interface;
@using Pinula.Shared.DTOs
@using Pinula.WASM.Components
@inject IRecipeService recipeService
@inject IJSRuntime JSRuntime

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (recipes != null && recipes.Any())
        {
            await JSRuntime.InvokeVoidAsync("setupHorizontalScroll");
        }
    }
}

<PageTitle>Pinula</PageTitle>

<h1>Recipes list</h1>

@if (recipes == null)
{
    <p><em>Loading recipes from api</em></p>
}
else if (!recipes.Any())
{
    <p>No recipes</p>
}
else
{
    <h3 class="mt-4">Favourite</h3>
        <div class="d-flex overflow-auto pb-2 no-scrollbar scroll-container">
            @foreach (var recipe in recipes)
            {
                <RecipeSimpleCard Recipe="recipe" OnRecipeSelected="RecipeClicked" />
            }
        </div>
        }

@code {
    private List<RecipePreviewDto>? recipes;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await recipeService.GetFilteredRecipePreviewsAsync(new RecipeFilterParametrs(), null);
            recipes = result?.ToList() ?? new List<RecipePreviewDto>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Loading error: {ex.Message}");
        }
    }

    public Task RecipeClicked()
    {
        return Task.CompletedTask;
    }
}