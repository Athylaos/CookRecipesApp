@page "/"
@using Pinula.Shared.Interface;
@using Pinula.Shared.DTOs
@inject IRecipeService recipeService

<PageTitle>Test API</PageTitle>

<h1>Recipes list</h1>

@if (recipes == null)
{
    <p><em>Loading recipes from api</em></p>
}
else if (!recipes.Any())
{
    <p>No recipes</p>
}
else
{
    <div class="row">
        @foreach (var recipe in recipes)
        {
            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@recipe.Title</h5>
                        <p class="card-text">@recipe.CookingTime</p>
                        <span class="badge bg-primary">@recipe.Calories</span>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<RecipePreviewDto>? recipes;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await recipeService.GetFilteredRecipePreviewsAsync(new RecipeFilterParametrs(), null);
            recipes = result?.ToList() ?? new List<RecipePreviewDto>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Loading error: {ex.Message}");
        }
    }
}