<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:models="clr-namespace:Pinula.Shared.Models;assembly=Pinula.Shared"
               xmlns:dtos="clr-namespace:Pinula.Shared.DTOs;assembly=Pinula.Shared"
               xmlns:modelsUI="clr-namespace:Pinula.ModelsUI"
               xmlns:viewmodel="clr-namespace:Pinula.ViewModel.Popups"
               x:Class="Pinula.View.Popups.RecipeFilterPopup"
               x:DataType="viewmodel:RecipeFilterViewModel"
               BackgroundColor="#1f1f1f"
               Shadow="Transparent 0 0"            
               >

    <Grid>
        <VerticalStackLayout MinimumWidthRequest="500">

            <Grid ColumnDefinitions="*, Auto, 30" Margin="0, 15, 0, 0" >
                <Label Text="Cooking time" FontFamily="Alegreya" FontSize="25" VerticalOptions="Center"/>
                <CheckBox Grid.Column="1" Color="{StaticResource PineTeal}" HorizontalOptions="Start" HeightRequest="45" WidthRequest="70" IsChecked="{Binding CookingTimeOn}"/>
            </Grid>
            <Grid ColumnDefinitions="*, 80">
                <Slider VerticalOptions="Center" Minimum="0" Maximum="9" MinimumTrackColor="{StaticResource PineTeal}" Value="{Binding TimeSliderValue}" IsEnabled="{Binding CookingTimeOn}"/>
                <Label Text="{Binding DisplayTime}" FontFamily="Nunito" FontSize="18" Grid.Column="1"/>
            </Grid>

            <Grid ColumnDefinitions="*, Auto, 30" Margin="0, 15, 0, 0" >
                <Label Text="Calories" FontFamily="Alegreya" FontSize="25" VerticalOptions="Center"/>
                <CheckBox Grid.Column="1" Color="{StaticResource PineTeal}" HorizontalOptions="Start" HeightRequest="45" WidthRequest="70" IsChecked="{Binding CaloriesOn}"/>
            </Grid>
            <Grid ColumnDefinitions="*, 80">
                <Slider VerticalOptions="Center" Minimum="0" Maximum="22" MinimumTrackColor="{StaticResource PineTeal}" Value="{Binding CaloriesSliderValue}" IsEnabled="{Binding CaloriesOn}"/>
                <Label Text="{Binding DisplayCalories}" FontFamily="Nunito" FontSize="18" Grid.Column="1"/>
            </Grid>

            <Grid ColumnDefinitions="*, Auto, 30" Margin="0, 15, 0, 0" >
                <Label Text="Rating" FontFamily="Alegreya" FontSize="25" VerticalOptions="Center"/>
                <Button Grid.Column="1" MaximumHeightRequest="33" Padding="0" Text="Clear" IsVisible="{Binding RatingOn}" Background="Transparent" Command="{Binding ClearRatingCommand}"/>
            </Grid>
            <CollectionView
                ItemsSource="{Binding RatingStars}"
                ItemsLayout="HorizontalList"
                HorizontalOptions="Center">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="modelsUI:RatingStar">
                        <ImageButton 
                            Source="{Binding Icon}"
                            WidthRequest="11" 
                            HeightRequest="11"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},Path=BindingContext.SelectRatingCommand}"
                            CommandParameter="{Binding RatingValue}"
                            Aspect="AspectFit"
                            Margin="2"
                            Padding="4"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Difficulty" FontFamily="Alegreya" FontSize="25" Margin="0, 15, 0, 0"/>
            <FlexLayout BindableLayout.ItemsSource="{Binding Difficulties}"
                Wrap="Wrap" 
                Direction="Row"
                JustifyContent="Center" 
                AlignContent="Start"
                AlignItems="Center">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="modelsUI:DifficultySelectable">
                        <Button Text="{Binding Name}"
                            Margin="3, 2"
                            WidthRequest="100" 
                            HeightRequest="40"
                            FontSize="13"
                            BorderColor="{StaticResource Evergreen}"
                            BorderWidth="1"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:RecipeFilterViewModel}}, Path=DifficultyBtnCommand}"
                            CommandParameter="{Binding .}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource PineTeal}"/>
                                    <Setter Property="TextColor" Value="{StaticResource Porcelain}"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding IsSelected}" Value="False">
                                    <Setter Property="BackgroundColor" Value="#212121" />
                                    <Setter Property="TextColor" Value="Silver"/>
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>

            <Grid ColumnDefinitions="*, Auto, 30" Margin="0, 15, 0, 0" >
                <Label Text="Only favorite" FontFamily="Alegreya" FontSize="25" VerticalOptions="Center"/>
                <CheckBox Grid.Column="1" Color="{StaticResource PineTeal}" HorizontalOptions="Start" HeightRequest="45" WidthRequest="70" IsChecked="{Binding OnlyFavorite}"/>
            </Grid>





            <Button
                Text="Apply"
                Margin="20, 30, 20, 0"
                Command="{Binding ApplyFiltersCommand}"
                CommandParameter="{Binding Source={RelativeSource AncestorType={x:Type toolkit:Popup}}}"
                BackgroundColor="{StaticResource PineTeal}"
                BorderColor="{StaticResource Evergreen}"
                BorderWidth="2"
                TextColor="{StaticResource Porcelain}"/>

            <Button
                Text="Cancel"
                Command="{Binding CancelCommand}"
                CommandParameter="{Binding Source={RelativeSource AncestorType={x:Type toolkit:Popup}}}"
                BackgroundColor="Transparent"
                TextColor="Gray" />
        </VerticalStackLayout>

    </Grid>
            

</toolkit:Popup>
