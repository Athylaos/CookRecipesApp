<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Pinula.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Pinula"
    xmlns:view="clr-namespace:Pinula.View"
    Title="Pinula">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate view:TestPage}"
        Route="TestPage" />
    
    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate view:DashboardPage}"
        Route="DashboardPage"/>
    

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate view:LoginPage}"
        Route="LoginPage"/>

    <ShellContent
        Title="RecipesMain"
        ContentTemplate="{DataTemplate view:RecipesMainPage}"
        Route="RecipesMainPage"/>


</Shell>
